generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Inspection {
  id                String   @id @default(cuid())
  createdAt         DateTime @default(now())
  imageUrls         String[]
  diagnosticoPrincipal String
  severidad         Int
  accionesInmediatas String[]
  recomendaciones   Json
  latitude          Float?
  longitude         Float?
  rawResponse       Json?
}
